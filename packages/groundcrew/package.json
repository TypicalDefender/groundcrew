{
  "name": "@clipboard-health/groundcrew",
  "version": "1.7.2",
  "description": "Linear-driven orchestrator that launches AI coding agents in git worktrees, with workspace lifecycle, remote runners, and usage tracking.",
  "keywords": [
    "agent",
    "ai",
    "claude",
    "codex",
    "linear",
    "orchestrator",
    "worktree"
  ],
  "bugs": "https://github.com/ClipboardHealth/core-utils/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClipboardHealth/core-utils.git",
    "directory": "packages/groundcrew"
  },
  "bin": {
    "crew": "./bin/run.js"
  },
  "files": [
    "README.md",
    "bin",
    "clearance-allow-hosts",
    "configExample.ts",
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@clipboard-health/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "tsgo --build tsconfig.lib.json"
  },
  "dependencies": {
    "@clipboard-health/clearance": "1.0.4",
    "@linear/sdk": "84.0.0",
    "tslib": "2.8.1"
  }
}
