{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["op", "taskkill"],
  "ignoreDependencies": ["@nx/js"],
  "workspaces": {
    ".": {
      "entry": [
        "bin/*.js",
        "config/lintStaged.config.js",
        "config/syncpack.config.ts",
        "config/vitestShared.ts",
        "crew.config.example.ts",
        "src/lib/adapters/*/index.ts",
        "src/main.ts"
      ]
    },
    "deck": {
      "entry": ["src/app/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@clipboard-health/groundcrew", "tailwindcss"]
    }
  }
}
