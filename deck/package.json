{
  "name": "@clipboard-health/groundcrew-deck",
  "version": "0.1.0",
  "private": true,
  "description": "Web dashboard for the crew: a live board of tasks, workspaces, and pull requests.",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 4400",
